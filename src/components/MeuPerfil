import { useState, useEffect } from "react";
import { supabase } from "@/lib/supabase";
import { User, ShieldCheck, Mail, Calendar, Key, Loader2, Award, Building } from "lucide-react";
import { toast } from "@/hooks/use-toast";

interface MeuPerfilProps {
  escolaNome: string;
}

const MeuPerfil = ({ escolaNome }: MeuPerfilProps) => {
  const [userData, setUserData] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [newPassword, setNewPassword] = useState("");
  const [isUpdating, setIsUpdating] = useState(false);

  useEffect(() => {
    fetchProfile();
  }, []);

  const fetchProfile = async () => {
    const { data: authData } = await supabase.auth.getUser();
    if (authData?.user) {
      setUserData(authData.user);
    }
    setLoading(false);
  };

  const handleUpdatePassword = async () => {
    if (newPassword.length < 6) {
      toast({ title: "Senha Fraca", description: "A nova senha deve ter pelo menos 6 caracteres.", variant: "destructive" });
      return;
    }

    setIsUpdating(true);
    const { error } = await supabase.auth.updateUser({ password: newPassword });
    setIsUpdating(false);

    if (error) {
      toast({ title: "Erro ao atualizar", description: error.message, variant: "destructive" });
    } else {
      toast({ title: "Sucesso", description: "Senha atualizada com segurança." });
      setNewPassword("");
    }
  };

  if (loading) {
    return <div className="flex justify-center py-12"><Loader2 className="w-8 h-8 animate-spin text-blue-600" /></div>;
  }

  // Pega a primeira letra do email para o Avatar
  const initial = userData?.email ? userData.email.charAt(0).toUpperCase() : "A";

  return (
    <div className="max-w-4xl mx-auto space-y-6 animate-in fade-in duration-500">
      
      {/* CAPA E AVATAR TIPO REDE SOCIAL CORPORATIVA */}
      <div className="bg-white rounded-3xl overflow-hidden shadow-sm border border-slate-200">
        {/* Header Cover (Banner) */}
        <div className="h-40 bg-gradient-to-r from-blue-700 via-indigo-800 to-slate-900 relative">
          <div className="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent blur-xl"></div>
        </div>
        
        {/* Info Area */}
        <div className="px-8 pb-8 relative">
          {/* Avatar Flutuante */}
          <div className="absolute -top-16 left-8 w-32 h-32 bg-white rounded-full p-2 shadow-lg">
            <div className="w-full h-full bg-slate-900 rounded-full flex items-center justify-center text-5xl font-black text-white border-4 border-slate-100">
              {initial}
            </div>
          </div>
          
          {/* Badge Oficial */}
          <div className="flex justify-end pt-4">
            <span className="bg-blue-50 text-blue-700 border border-blue-200 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest flex items-center gap-2 shadow-sm">
              <ShieldCheck className="w-4 h-4" /> Conta Oficial Verificada
            </span>
          </div>

          <div className="mt-8">
            <h1 className="text-3xl font-black text-slate-800 tracking-tight">Administrador Chefe</h1>
            <p className="text-slate-500 font-medium flex items-center gap-2 mt-1">
              <Mail className="w-4 h-4" /> {userData?.email}
            </p>
          </div>

          {/* Cards de Status do Perfil */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
            <div className="bg-slate-50 border border-slate-100 p-4 rounded-2xl flex items-start gap-4">
              <div className="bg-blue-100 text-blue-600 p-3 rounded-xl"><Building className="w-6 h-6" /></div>
              <div>
                <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Instituição Vinculada</p>
                <p className="font-black text-slate-800">{escolaNome}</p>
              </div>
            </div>

            <div className="bg-slate-50 border border-slate-100 p-4 rounded-2xl flex items-start gap-4">
              <div className="bg-indigo-100 text-indigo-600 p-3 rounded-xl"><Award className="w-6 h-6" /></div>
              <div>
                <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Nível de Acesso</p>
                <p className="font-black text-slate-800">Mestre (Nível 5)</p>
              </div>
            </div>

            <div className="bg-slate-50 border border-slate-100 p-4 rounded-2xl flex items-start gap-4">
              <div className="bg-green-100 text-green-600 p-3 rounded-xl"><Calendar className="w-6 h-6" /></div>
              <div>
                <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Perfil Criado Em</p>
                <p className="font-black text-slate-800">
                  {userData?.created_at ? new Date(userData.created_at).toLocaleDateString('pt-BR') : "Indisponível"}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* ÁREA DE SEGURANÇA */}
      <div className="bg-white p-8 rounded-3xl shadow-sm border border-slate-200">
        <div className="flex items-center gap-3 mb-6 border-b border-slate-100 pb-4">
          <div className="p-3 bg-slate-100 text-slate-600 rounded-xl"><Key className="w-6 h-6" /></div>
          <div>
            <h2 className="text-xl font-black text-slate-800">Segurança da Conta</h2>
            <p className="text-sm text-slate-500 font-medium">Atualize a sua palavra-passe de acesso ao sistema.</p>
          </div>
        </div>

        <div className="max-w-md">
          <label className="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 block">Nova Palavra-Passe</label>
          <div className="flex gap-3">
            <input 
              type="password" 
              placeholder="Digite a nova senha..." 
              className="flex-1 p-3 border border-slate-200 rounded-xl bg-slate-50 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all"
              value={newPassword}
              onChange={e => setNewPassword(e.target.value)}
            />
            <button 
              onClick={handleUpdatePassword}
              disabled={isUpdating || newPassword.length < 6}
              className="bg-slate-900 hover:bg-slate-800 text-white px-6 py-3 rounded-xl font-bold text-sm transition-colors disabled:opacity-50 flex items-center gap-2"
            >
              {isUpdating ? <Loader2 className="w-4 h-4 animate-spin" /> : "Atualizar"}
            </button>
          </div>
          <p className="text-[10px] text-slate-400 mt-2 font-medium">Use uma combinação forte de letras e números para proteger os dados da escola.</p>
        </div>
      </div>

    </div>
  );
};

export default MeuPerfil;
